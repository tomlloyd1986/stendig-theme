      "settings": {
        "title": "When Charles met Massimo",
        "standfirst": "How a furniture dealer and a designer made a calendar that never went out of style"
      }
    },
    "content": {
      "type": "blog-content",
      "blocks": {
        "images_87HkVi": {
          "type": "images",
