{% comment %}
  Native editorial "2026 Collection" layout — theme-side replica of the
  PageFly range page. Header (heading left / intro right), a divider, then
  a grid of GENUINE product cards: the Stendig, each V Calendar colour
  (rendered per variant with its own image/link), and the Hanging Strips.
{% endcomment %}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign stendig = all_products[section.settings.product_1]
  assign vcal = all_products[section.settings.product_variants]
  assign strips = all_products[section.settings.product_3]
-%}

{% style %}
  .c26 { padding: 4rem 0 6rem; }
  .c26__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
    align-items: start;
  }
  @media screen and (min-width: 990px) {
    .c26__head { grid-template-columns: 1fr 1fr; gap: 6rem; }
  }
  .c26__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.8rem, 4vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 0;
  }
  .c26__lede {
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
    max-width: 52rem;
  }
  .c26__divider {
    height: 0.1rem;
    background: rgba(var(--color-foreground), 0.15);
    margin: 3.2rem 0 4.8rem;
  }
  .c26__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem 3.2rem;
  }
  @media screen and (min-width: 750px) {
    .c26__grid { grid-template-columns: repeat(4, 1fr); }
  }
  .c26__grid .card-wrapper { height: 100%; }
{% endstyle %}

<div class="c26 page-width">
  <div class="c26__head">
    <h1 class="c26__heading">{{ section.settings.heading | default: 'The 2026 Collection' }}</h1>
    {%- if section.settings.intro != blank -%}
      <p class="c26__lede">{{ section.settings.intro }}</p>
    {%- endif -%}
  </div>

  <div class="c26__divider"></div>

  <div class="c26__grid">
    {%- if stendig != blank -%}
      {% render 'product-card', product_card_product: stendig, media_size: 'adapt', show_secondary_image: false, show_image_outline: false, card_index: 1 %}
    {%- endif -%}

    {%- if vcal != blank -%}
      {%- for variant in vcal.variants -%}
        {%- capture v_title -%}{{ vcal.title }} ({{ variant.title }}){%- endcapture -%}
        {% render 'product-card', product_card_product: vcal, card_variant: variant, card_title: v_title, media_size: 'adapt', show_secondary_image: false, show_image_outline: false %}
      {%- endfor -%}
    {%- endif -%}

    {%- if strips != blank -%}
      {% render 'product-card', product_card_product: strips, media_size: 'adapt', show_secondary_image: false, show_image_outline: false %}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "2026 Collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The 2026 Collection" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Massimo Vignelli's classic is joined by a modern reinvention, this year available in a choice of four different colours. Purchase a Stendig and V together, and receive an automatic discount at checkout." },
    { "type": "header", "content": "Products" },
    { "type": "text", "id": "product_1", "label": "First product handle", "default": "stendig-calendar" },
    { "type": "text", "id": "product_variants", "label": "Variant-split product handle (one card per variant)", "default": "v-calendar" },
    { "type": "text", "id": "product_3", "label": "Last product handle", "default": "hanging-strips" }
  ],
  "presets": [{ "name": "2026 Collection" }]
}
{% endschema %}
