{% comment %}
  Native editorial "2026 Collection" layout — theme-side replica of the
  PageFly range page. Header (heading left / intro right) + divider, then
  the theme's genuine collection grid: the Stendig, each V Calendar colour
  (one card per variant, its own image/link), and the Hanging Strips.
{% endcomment %}

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-product-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign stendig = all_products[section.settings.product_1]
  assign vcal = all_products[section.settings.product_variants]
  assign strips = all_products[section.settings.product_3]
-%}

{% style %}
  /* Top/bottom only: a padding shorthand here would zero out the
     horizontal padding .page-width provides on the same element. */
  .c26 { padding-top: 5rem; padding-bottom: 6rem; }
  .c26__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
    align-items: start;
  }
  @media screen and (min-width: 990px) {
    .c26__head { grid-template-columns: 1fr 1fr; column-gap: 6rem; }
  }
  .c26__heading {
    font-family: var(--font-heading-family);
    font-size: 2.8rem;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 0;
  }
  @media screen and (min-width: 750px) {
    .c26__heading { font-size: {{ section.settings.heading_size | default: 36 }}px; }
  }
  .c26__lede {
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
    max-width: 52rem;
  }
  .c26__divider {
    border: none;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.15);
    margin: 3rem 0 4rem;
  }
  @media screen and (min-width: 750px) {
    .c26__divider { margin-bottom: {{ section.settings.gap_below_divider | default: 96 }}px; }
  }
  .c26 .card-information__text.h5 { font-size: 1.4rem; }
  .c26 .price { font-size: 1.4rem; letter-spacing: 0.06rem; }
{% endstyle %}

<div class="c26 page-width">
  <div class="c26__head">
    <h1 class="c26__heading">{{ section.settings.heading | default: 'The 2026 Collection' }}</h1>
    {%- if section.settings.intro != blank -%}
      <p class="c26__lede">{{ section.settings.intro }}</p>
    {%- endif -%}
  </div>

  <hr class="c26__divider">

  <ul class="grid grid--2-col grid--3-col-tablet grid--4-col-desktop grid--quarter-max grid--one-third-max product-grid negative-margin" role="list">
    {%- if stendig != blank -%}
      <li class="grid__item">
        {% render 'product-card', product_card_product: stendig, media_size: 'adapt', show_secondary_image: false, show_image_outline: false, card_index: 1 %}
      </li>
    {%- endif -%}

    {%- if vcal != blank -%}
      {%- for variant in vcal.variants -%}
        {%- capture v_title -%}{{ vcal.title }} ({{ variant.title }}){%- endcapture -%}
        <li class="grid__item">
          {% render 'product-card', product_card_product: vcal, card_variant: variant, card_title: v_title, media_size: 'adapt', show_secondary_image: false, show_image_outline: false %}
        </li>
      {%- endfor -%}
    {%- endif -%}

    {%- if strips != blank -%}
      <li class="grid__item">
        {% render 'product-card', product_card_product: strips, media_size: 'adapt', show_secondary_image: false, show_image_outline: false %}
      </li>
    {%- endif -%}
  </ul>
</div>

{% schema %}
{
  "name": "2026 Collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The 2026 Collection" },
    { "type": "range", "id": "heading_size", "label": "Heading size (desktop)", "min": 28, "max": 56, "step": 2, "unit": "px", "default": 36 },
    { "type": "range", "id": "gap_below_divider", "label": "Space below divider (desktop)", "min": 40, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Massimo Vignelli's classic is joined by a modern reinvention, this year available in a choice of four different colours. Purchase a Stendig and V together, and receive an automatic discount at checkout." },
    { "type": "header", "content": "Products" },
    { "type": "text", "id": "product_1", "label": "First product handle", "default": "stendig-calendar" },
    { "type": "text", "id": "product_variants", "label": "Variant-split product handle (one card per variant)", "default": "v-calendar" },
    { "type": "text", "id": "product_3", "label": "Last product handle", "default": "hanging-strips" }
  ],
  "presets": [{ "name": "2026 Collection" }]
}
{% endschema %}
