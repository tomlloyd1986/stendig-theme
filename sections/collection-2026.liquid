{% comment %}
  Native editorial "2026 Collection" layout — theme-side replica of the
  PageFly range page. Header (heading left / intro right) + divider, then
  the theme's genuine collection grid: the Stendig, each V Calendar colour
  (one card per variant, its own image/link), and the Hanging Strips.
{% endcomment %}

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-product-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign stendig = all_products[section.settings.product_1]
  assign vcal = all_products[section.settings.product_variants]
  assign strips = all_products[section.settings.product_3]
-%}

{% style %}
  /* Values transplanted from the live PageFly page's published CSS
     (pf-heading-2-h1, pf-text-7, pf-heading-7-h3, pf-text-2, pf-11_,
     pf-20_, pf-28_, gkLnU divider) so the native page renders identically.
     Top/bottom padding only: a shorthand would zero out the horizontal
     padding .page-width provides on the same element. */
  .c26 { padding-top: 6rem; padding-bottom: 2rem; }
  .c26__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.4rem;
    align-items: start;
  }
  @media screen and (min-width: 750px) {
    .c26__head { grid-template-columns: 1fr 1fr; column-gap: 6rem; }
  }
  /* No font-family here: the theme's h1 rule supplies Display 45 Light,
     the same file PageFly loads as "NeueHaasGrotDisp 45Light". */
  .c26__heading {
    font-size: {{ section.settings.heading_size | default: 32 }}px;
    line-height: 1.3;
    font-weight: 400;
    margin: 0;
    padding-top: 0.8rem;
    color: #000;
  }
  .c26__lede {
    font-size: 1.4rem;
    line-height: 2.1rem;
    letter-spacing: 0;
    color: #000;
    margin: 0;
  }
  .c26__divider {
    border: none;
    border-top: 2px solid #d4d4d4;
    margin: 8rem 0 {{ section.settings.gap_below_divider | default: 100 }}px;
  }
  /* Card titles/prices match the intro exactly: Text 55 Roman 14px/21px.
     (The theme's h5 rule would otherwise set titles in Display Light.) */
  .c26 .card-information__text.h5 {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    line-height: 2.1rem;
    letter-spacing: 0;
  }
  .c26 .card-information__text.h5 .full-unstyled-link { color: #000; }
  .c26 .price { font-size: 1.4rem; letter-spacing: 0; color: #000; }
  .c26 .price .product__tax { display: none; }
  .c26 .card-information__wrapper > *:not(.visually-hidden:first-child) + *:not(.rating) { margin-top: 0.3rem; }
  .c26 .card-information + .card { margin-bottom: 1rem; }
  .c26 .product-grid .grid__item { padding-bottom: 3.5rem; }
{% endstyle %}

<div class="c26 page-width">
  <div class="c26__head">
    <h1 class="c26__heading">{{ section.settings.heading | default: 'The 2026 Collection' }}</h1>
    {%- if section.settings.intro != blank -%}
      <p class="c26__lede">{{ section.settings.intro }}</p>
    {%- endif -%}
  </div>

  <hr class="c26__divider">

  <ul class="grid grid--2-col grid--3-col-tablet grid--4-col-desktop grid--quarter-max grid--one-third-max product-grid" role="list">
    {%- if stendig != blank -%}
      <li class="grid__item">
        {% render 'product-card', product_card_product: stendig, media_size: 'adapt', show_secondary_image: false, show_image_outline: false, card_index: 1 %}
      </li>
    {%- endif -%}

    {%- if vcal != blank -%}
      {%- for variant in vcal.variants -%}
        {%- capture v_title -%}{{ vcal.title }} ({{ variant.title }}){%- endcapture -%}
        <li class="grid__item">
          {% render 'product-card', product_card_product: vcal, card_variant: variant, card_title: v_title, media_size: 'adapt', show_secondary_image: false, show_image_outline: false %}
        </li>
      {%- endfor -%}
    {%- endif -%}

    {%- if strips != blank -%}
      <li class="grid__item">
        {% render 'product-card', product_card_product: strips, media_size: 'adapt', show_secondary_image: false, show_image_outline: false %}
      </li>
    {%- endif -%}
  </ul>
</div>

{% schema %}
{
  "name": "2026 Collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The 2026 Collection" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 24, "max": 56, "step": 2, "unit": "px", "default": 32 },
    { "type": "range", "id": "gap_below_divider", "label": "Space below divider", "min": 40, "max": 164, "step": 4, "unit": "px", "default": 100 },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Massimo Vignelli's classic is joined by a modern reinvention, this year available in a choice of four different colours. Purchase a Stendig and V together, and receive an automatic discount at checkout." },
    { "type": "header", "content": "Products" },
    { "type": "text", "id": "product_1", "label": "First product handle", "default": "stendig-calendar" },
    { "type": "text", "id": "product_variants", "label": "Variant-split product handle (one card per variant)", "default": "v-calendar" },
    { "type": "text", "id": "product_3", "label": "Last product handle", "default": "hanging-strips" }
  ],
  "presets": [{ "name": "2026 Collection" }]
}
{% endschema %}
