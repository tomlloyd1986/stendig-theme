{% comment %}
  Native editorial "2026 Collection" layout — a theme-side replica of the
  PageFly range page (pf-2e4a327b). Curated cards for the Stendig, the four
  V Calendar colours, and the Hanging Strips, with 4:5 lifestyle imagery.
  Prices pull live from the products; images are the curated Files assets.
{% endcomment %}

{%- liquid
  assign stendig = all_products['stendig-calendar']
  assign vcal = all_products['v-calendar']
  assign strips = all_products['hanging-strips']
  assign img_base = 'https://cdn.shopify.com/s/files/1/0601/3104/9710/files/'
-%}

{% style %}
  #shopify-section-{{ section.id }} { --c26-gap: 3.2rem; }
  .c26 { padding: 4rem 0 6rem; }
  .c26__intro { max-width: 68rem; margin: 0 auto; text-align: center; padding: 0 2rem; }
  .c26__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(3.2rem, 6vw, 5.2rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 400;
    margin: 0 0 1.6rem;
  }
  .c26__lede {
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }
  .c26__divider {
    width: 100%;
    height: 0.1rem;
    background: rgba(var(--color-foreground), 0.15);
    margin: 4.8rem 0;
  }
  .c26__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--c26-gap);
  }
  @media screen and (min-width: 750px) {
    .c26__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .c26__card { display: block; text-decoration: none; color: rgb(var(--color-foreground)); }
  .c26__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }
  .c26__media img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .c26__card:hover .c26__media img { transform: scale(1.03); }
  .c26__info { padding: 1.4rem 0 0; display: flex; justify-content: space-between; gap: 1.2rem; align-items: baseline; }
  .c26__title { font-size: 1.5rem; font-weight: 400; margin: 0; }
  .c26__price { font-size: 1.5rem; margin: 0; white-space: nowrap; display: flex; gap: 0.8rem; align-items: baseline; }
  .c26__price s { color: rgba(var(--color-foreground), 0.4); }
{% endstyle %}

<div class="c26 page-width">
  <div class="c26__intro">
    <h1 class="c26__heading">{{ section.settings.heading | default: 'The 2026 Collection' }}</h1>
    <p class="c26__lede">{{ section.settings.intro }}</p>
  </div>

  <div class="c26__divider"></div>

  <div class="c26__grid">
    {%- comment -%} 1. Stendig {%- endcomment -%}
    <a class="c26__card" href="{{ stendig.url }}">
      <div class="c26__media">
        <img src="{{ img_base }}STENDIG_Calanders_Web_Res_4x5_JdeWaart_8.8.25_2_1a5435d6-baa1-4133-8839-4af5b53a2d98.jpg?v=1755081095&width=800" alt="Stendig Calendar 2026" loading="lazy" width="800" height="1000">
      </div>
      <div class="c26__info">
        <p class="c26__title">Stendig Calendar 2026</p>
        <p class="c26__price">
          <span>{{ stendig.price | money }}</span>
          {%- if stendig.compare_at_price > stendig.price -%}<s>{{ stendig.compare_at_price | money }}</s>{%- endif -%}
        </p>
      </div>
    </a>

    {%- comment -%} 2. V Calendar White {%- endcomment -%}
    <a class="c26__card" href="/products/v-calendar">
      <div class="c26__media">
        <img src="{{ img_base }}STENDIG_Calanders_Web_Res_4x5_JdeWaart_8.8.25_40.jpg?v=1754953103&width=800" alt="V Calendar 2026 White" loading="lazy" width="800" height="1000">
      </div>
      <div class="c26__info">
        <p class="c26__title">V Calendar 2026 (White)</p>
        <p class="c26__price"><span>{{ vcal.price | money }}</span></p>
      </div>
    </a>

    {%- comment -%} 3. V Calendar Black {%- endcomment -%}
    <a class="c26__card" href="/products/v-calendar">
      <div class="c26__media">
        <img src="{{ img_base }}STENDIG_Calanders_Web_Res_4x5_JdeWaart_8.8.25_23.jpg?v=1754953084&width=800" alt="V Calendar 2026 Black" loading="lazy" width="800" height="1000">
      </div>
      <div class="c26__info">
        <p class="c26__title">V Calendar 2026 (Black)</p>
        <p class="c26__price"><span>{{ vcal.price | money }}</span></p>
      </div>
    </a>

    {%- comment -%} 4. V Calendar Red {%- endcomment -%}
    <a class="c26__card" href="/products/v-calendar?variant=45540628136174">
      <div class="c26__media">
        <img src="{{ img_base }}STENDIG_Calanders_Web_Res_4x5_JdeWaart_8.8.25_13.jpg?v=1754953076&width=800" alt="V Calendar 2026 Red" loading="lazy" width="800" height="1000">
      </div>
      <div class="c26__info">
        <p class="c26__title">V Calendar 2026 (Red)</p>
        <p class="c26__price"><span>{{ vcal.price | money }}</span></p>
      </div>
    </a>

    {%- comment -%} 5. V Calendar Yellow {%- endcomment -%}
    <a class="c26__card" href="/products/v-calendar?variant=46870524690670">
      <div class="c26__media">
        <img src="{{ img_base }}STENDIG_Calanders_Web_Res_4x5_JdeWaart_8.8.25_32.jpg?v=1754953092&width=800" alt="V Calendar 2026 Yellow" loading="lazy" width="800" height="1000">
      </div>
      <div class="c26__info">
        <p class="c26__title">V Calendar 2026 (Yellow)</p>
        <p class="c26__price"><span>{{ vcal.price | money }}</span></p>
      </div>
    </a>

    {%- comment -%} 6. Hanging Strips {%- endcomment -%}
    <a class="c26__card" href="{{ strips.url }}">
      <div class="c26__media">
        <img src="{{ img_base }}Hanging_strips_4x5_ebe35195-b726-43a6-b1c0-7f3e023cf4db.jpg?v=1754953339&width=800" alt="Hanging Strips for the Stendig" loading="lazy" width="800" height="1000">
      </div>
      <div class="c26__info">
        <p class="c26__title">Hanging Strips (for the Stendig)</p>
        <p class="c26__price"><span>{{ strips.price | money }}</span></p>
      </div>
    </a>
  </div>
</div>

{% schema %}
{
  "name": "2026 Collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The 2026 Collection" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Massimo Vignelli's classic is joined by a modern reinvention, this year available in a choice of four different colours. Purchase a Stendig and V together, and receive an automatic discount at checkout." }
  ],
  "presets": [{ "name": "2026 Collection" }]
}
{% endschema %}
