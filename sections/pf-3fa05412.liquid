a8b_26ffdaea_500.jpg?v=1762468040&width=1280 1280w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_501e903c0df7c391fe956d0243059a8b_26ffdaea_500.jpg?v=1762468040&width=1440 1440w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_501e903c0df7c391fe956d0243059a8b_26ffdaea_500.jpg?v=1762468040&width=1680 1680w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_501e903c0df7c391fe956d0243059a8b_26ffdaea_500.jpg?v=1762468040&width=1800 1800w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_501e903c0df7c391fe956d0243059a8b_26ffdaea_500.jpg?v=1762468040&width=1920 1920w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_501e903c0df7c391fe956d0243059a8b_26ffdaea_500.jpg?v=1762468040&width=2048 2048w" fetchPriority="low" decoding="async" loading="lazy" style="--pf-image-ratio:0.7441130298273155" width="474" height="637" sizes="75vw" data-pf-type="Image4" class="sc-pKreJ jowHiA pf-36_" store="[object Object]"/><img alt="knoll.jpg__PID:5ff1a00a-b5fd-4a0c-90bf-8021c375802c" src="https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=2048" srcSet="https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=375 375w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=550 550w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=768 768w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=1024 1024w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=1280 1280w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=1440 1440w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=1680 1680w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=1800 1800w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=1920 1920w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/knoll.jpg?v=1762467969&width=2048 2048w" fetchPriority="low" decoding="async" loading="lazy" style="--pf-image-ratio:1.492537313432836" width="1200" height="804" sizes="75vw" data-pf-type="Image4" class="sc-pKreJ jowHiA pf-37_" store="[object Object]"/></div></div></div><div class="sc-hzhKNl fltMam pf-38_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-39_"><p class="sc-iowYbt eEPszQ pf-40_ pf-text-3" data-pf-type="Paragraph4"><input type="checkbox" id="compact-a794ccb4-1ed2-4029-97ac-235fc85dcbd9"/><span class="pf-paragraph-content ">As cohabitants of the same building, Vignelli and Stendig soon crossed paths. Stendig enlisted the help of the designer in creating a brand identity, built around a simple, bold Helvetica logo. Sometime around the middle of 1966, Stendig mentioned he was looking for a promotional gift -&nbsp;something to send to clients to thank them for their custom that wouldn’t end up in a drawer.<br><br>Vignelli had long imagined a large wall calendar: pure typography, no images, no ornament. “We had always wanted to design a large calendar,” he later said. “Stendig provided us with such an opportunity.”<br></span></p></div></div></div><div class="sc-hzhKNl fltMam pf-43_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-44_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-45_ pf-heading-2-h3">"We had always wanted to design a large calendar. Stendig provided us with such an opportunity.”</h3><p class="sc-iowYbt eEPszQ pf-47_ pf-text-2" data-pf-type="Paragraph4"><input type="checkbox" id="compact-f20beca7-2dab-4430-9068-5094043e77fb"/><span class="pf-paragraph-content ">Massimo Vignelli</span></p></div></div></div><div class="sc-hzhKNl fltMam pf-50_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-51_"><p class="sc-iowYbt eEPszQ pf-52_ pf-text-3" data-pf-type="Paragraph4"><input type="checkbox" id="compact-0ad1ad61-abab-483b-a199-b56adfeef6c4"/><span class="pf-paragraph-content ">The first Stendig Calendar, printed in 1966 for the year 1967, was immense - three feet by four feet - and striking in its restraint. Each month was set in Helvetica, alternating black and white backgrounds in a crisp visual rhythm. Double-digit numerals were closely kerned, so as to just “kiss”, creating a pleasing tightness within the expansive space of the sheet. For Vignelli, the space around the numbers was every bit as important as the numbers themselves.<br></span></p></div></div></div><div class="sc-hzhKNl fltMam pf-55_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-56_"><img alt="2014-0527-Vignelli-SS-articleLarge.webp__PID:e4e9c38e-77bb-4305-8991-c06f4fe39c20" src="https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=2048" srcSet="https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=375 375w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=550 550w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=768 768w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=1024 1024w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=1280 1280w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=1440 1440w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=1680 1680w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=1800 1800w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=1920 1920w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/2014-0527-Vignelli-SS-articleLarge.webp?v=1762517367&width=2048 2048w" fetchPriority="low" decoding="async" loading="lazy" style="--pf-image-ratio:1.5" width="600" height="400" sizes="75vw" data-pf-type="Image4" class="sc-pKreJ jowHiA pf-57_" store="[object Object]"/></div></div></div><div class="sc-hzhKNl fltMam pf-58_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-59_"><p class="sc-iowYbt eEPszQ pf-60_ pf-text-3" data-pf-type="Paragraph4"><input type="checkbox" id="compact-d863ca37-f123-4312-9ab5-2e0edbd8c0b9"/><span class="pf-paragraph-content ">Stendig was delighted. When the first copies arrived from the printer, he sent them out as gifts to clients and friends across New York and the country. Before long, the calendars were hanging in living rooms, studios and offices from coast to coast. They were a hit, and became an instant classic of modernist graphic design.</span></p></div></div></div><div class="sc-hzhKNl fltMam pf-63_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-64_"><img alt="tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280 (1).jpg__PID:9d85acc4-6deb-40d3-943b-6ab63722cd5d" src="https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=2048" srcSet="https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=375 375w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=550 550w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=768 768w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=1024 1024w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=1280 1280w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=1440 1440w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=1680 1680w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=1800 1800w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=1920 1920w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_1e473653351ff1fa76289cd875596681_9c7a4130_1280_1.jpg?v=1762467436&width=2048 2048w" fetchPriority="low" decoding="async" loading="lazy" style="--pf-image-ratio:1.4883720930232558" width="1280" height="860" sizes="75vw" data-pf-type="Image4" class="sc-pKreJ jowHiA pf-65_" store="[object Object]"/><img alt="tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg__PID:a25f0512-f99f-4c79-a317-b309f717cf8f" src="https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=2048" srcSet="https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=375 375w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=550 550w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=768 768w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=1024 1024w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=1280 1280w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=1440 1440w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=1680 1680w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=1800 1800w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=1920 1920w,https://cdn.shopify.com/s/files/1/0601/3104/9710/files/tumblr_nh1oqpmNmf1r0r8u6o1_1280.jpg?v=1762468589&width=2048 2048w" fetchPriority="low" decoding="async" loading="lazy" style="--pf-image-ratio:1.6371077762619373" width="1200" height="733" sizes="75vw" data-pf-type="Image4" class="sc-pKreJ jowHiA pf-66_" store="[object Object]"/></div></div></div><div class="sc-hzhKNl fltMam pf-67_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-68_"><p class="sc-iowYbt eEPszQ pf-69_ pf-text-3" data-pf-type="Paragraph4"><input type="checkbox" id="compact-ae225692-6b68-4aba-93cf-9aecab7dfa07"/><span class="pf-paragraph-content ">The Museum of Modern Art agreed. Only months after its first edition was printed, MoMA added the Stendig Calendar to its permanent design collection, where it remains to this day. <br><br>Six decades on, the Stendig Calendar now marks the months on walls around the world, from Tokyo to Toronto, Sydney to Stockholm. 2026 will be its sixtieth edition, with a design unchanged from Vignelli’s original - the same type, the same size, the same simplicity. After all, as Massimo famously observed, “if you do it right, it will last forever”.<br><br><i>Images courtesy of the Vignelli Centre</i><br></span></p></div></div></div></div></div></div></div></div><script>
