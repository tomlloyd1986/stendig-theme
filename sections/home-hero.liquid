{% comment %}
  Hero banner — native rebuild of the PageFly home-page hero.
  Full-bleed image below the header with a bottom-centred button; the whole
  hero is one link. Three image crops (desktop / tablet / mobile) with the
  desktop image as fallback. Height fills the viewport below the measured
  header (--st-header-bottom, kept in sync by the header section).
  Editable: images, button label, link. Spacing/typography locked.
{% endcomment %}

{%- liquid
  assign img_d = section.settings.image_desktop
  assign img_t = section.settings.image_tablet | default: img_d
  assign img_m = section.settings.image_mobile | default: img_d
  assign hero_link = section.settings.link | default: '/collections/range'
  assign button_label = section.settings.button_label
-%}

{% style %}
  #shopify-section-{{ section.id }} .hero {
    padding: 0 20px;
  }
  #shopify-section-{{ section.id }} .hero__link {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    overflow: hidden;
    height: calc(100vh - var(--st-header-bottom, 64px) - 20px);
    height: calc(100svh - var(--st-header-bottom, 64px) - 20px);
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .hero__media,
  #shopify-section-{{ section.id }} .hero__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ section.id }} .hero__media img {
    object-fit: cover;
    object-position: center center;
  }
  #shopify-section-{{ section.id }} .hero__placeholder {
    position: absolute;
    inset: 0;
    background: #f3f3f3;
  }
  #shopify-section-{{ section.id }} .hero__button {
    position: relative;
    z-index: 1;
    background-color: #161616;
    color: #fff;
    font-family: var(--font-body-family);
    font-size: 16px;
    line-height: 16px;
    font-weight: 400;
    letter-spacing: 0;
    padding: 16px 26px;
    margin-bottom: 30px;
    text-align: center;
  }
  @media screen and (max-width: 989px) {
    /* Smaller screens anchor the image to its bottom edge, like the live site */
    #shopify-section-{{ section.id }} .hero__media img {
      object-position: center bottom;
    }
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .hero { padding: 0 12px; }
  }
{% endstyle %}

<div class="hero">
  <a
    href="{{ hero_link }}"
    class="hero__link"
    {% if button_label != blank %}aria-label="{{ button_label | escape }}"{% endif %}
  >
    {%- if img_d != blank -%}
      <picture class="hero__media">
        {%- if img_m != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="{{ img_m | image_url: width: 750 }} 750w, {{ img_m | image_url: width: 1100 }} 1100w, {{ img_m | image_url: width: 1500 }} 1500w"
            sizes="100vw"
          >
        {%- endif -%}
        {%- if img_t != blank -%}
          <source
            media="(max-width: 989px)"
            srcset="{{ img_t | image_url: width: 1100 }} 1100w, {{ img_t | image_url: width: 1600 }} 1600w, {{ img_t | image_url: width: 2048 }} 2048w"
            sizes="100vw"
          >
        {%- endif -%}
        <img
          src="{{ img_d | image_url: width: 2048 }}"
          srcset="{{ img_d | image_url: width: 1400 }} 1400w, {{ img_d | image_url: width: 2048 }} 2048w, {{ img_d | image_url: width: 2600 }} 2600w"
          sizes="100vw"
          width="{{ img_d.width }}"
          height="{{ img_d.height }}"
          alt="{{ img_d.alt | escape }}"
          fetchpriority="high"
        >
      </picture>
    {%- else -%}
      <span class="hero__placeholder" role="presentation"></span>
    {%- endif -%}

    {%- if button_label != blank -%}
      <span class="hero__button">{{ button_label | escape }}</span>
    {%- endif -%}
  </a>
</div>

{% schema %}
{
  "name": "Home: Hero banner",
  "settings": [
    { "type": "image_picker", "id": "image_desktop", "label": "Image — desktop" },
    { "type": "image_picker", "id": "image_tablet", "label": "Image — tablet", "info": "Optional. Falls back to the desktop image." },
    { "type": "image_picker", "id": "image_mobile", "label": "Image — mobile", "info": "Optional. Falls back to the desktop image." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "DISCOVER 2026" },
    { "type": "url", "id": "link", "label": "Link", "info": "Where the button — and the whole hero — points. Defaults to the range collection." }
  ],
  "presets": [
    { "name": "Home: Hero banner" }
  ]
}
{% endschema %}
