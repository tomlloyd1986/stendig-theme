{% comment %}
  Home: From the press — native rebuild of the PageFly press-quote slider,
  redesigned per the Claude Design handoff (Turn 7, "masthead index"):
  one quote at display scale, every publication listed beneath as the
  switcher (click a name to change the quote), one fixed photo beside it.
  No stars, no beige background, no arrows, no auto-rotate.
  Editable: eyebrow, image, and quote blocks (quote text + publication
  name, up to 8). Layout, type and spacing locked.
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .press {
    display: block;
    padding: 0 20px 64px;
  }
  #shopify-section-{{ section.id }} .press__divider {
    border: none;
    border-top: 1px solid #e2e2e2;
    margin: 0 0 14px;
  }
  #shopify-section-{{ section.id }} .press__eyebrow {
    font-family: var(--font-body-family);
    font-size: 14px;
    line-height: 21px;
    font-weight: 400;
    letter-spacing: 0;
    color: #121212;
    margin: 0 0 48px;
  }

  #shopify-section-{{ section.id }} .press__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    align-items: center;
  }
  #shopify-section-{{ section.id }} .press__image {
    order: 2;
  }
  #shopify-section-{{ section.id }} .press__image img {
    display: block;
    width: 100%;
    aspect-ratio: 5 / 6;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .press__placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 5 / 6;
    background: #f3f3f3;
  }

  #shopify-section-{{ section.id }} .press__quote {
    display: none;
    margin: 0 0 40px;
    font-family: "Neue Haas Grotesk Display", var(--font-heading-family), sans-serif;
    font-weight: 300;
    font-size: 44px;
    line-height: 1.25;
    color: #121212;
    text-wrap: pretty;
    min-height: 220px;
  }
  #shopify-section-{{ section.id }} .press__quote.is-active { display: block; }

  #shopify-section-{{ section.id }} .press__pubs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 24px;
  }
  #shopify-section-{{ section.id }} .press__pub {
    background: none;
    border: none;
    border-bottom: 1px solid transparent;
    padding: 0 0 2px;
    margin: 0;
    font-family: var(--font-body-family);
    font-size: 14px;
    line-height: 21px;
    font-weight: 400;
    letter-spacing: 0;
    color: #b8b8b8;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .press__pub.is-active {
    color: #121212;
    border-bottom-color: #121212;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .press__grid {
      grid-template-columns: 1fr 480px;
      gap: 80px;
    }
    #shopify-section-{{ section.id }} .press__image { order: initial; }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} .press {
      padding: 0 20px 56px;
    }
    #shopify-section-{{ section.id }} .press__eyebrow { margin-bottom: 40px; }
    #shopify-section-{{ section.id }} .press__grid { grid-template-columns: 1fr 280px; gap: 44px; }
    #shopify-section-{{ section.id }} .press__quote {
      font-size: 30px;
      line-height: 1.28;
      min-height: 190px;
      margin-bottom: 32px;
    }
    #shopify-section-{{ section.id }} .press__pubs { gap: 10px 20px; }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .press { padding: 0 12px 48px; }
    #shopify-section-{{ section.id }} .press__eyebrow { margin-bottom: 32px; }
    #shopify-section-{{ section.id }} .press__quote {
      font-size: 26px;
      line-height: 1.3;
      min-height: 170px;
      margin-bottom: 28px;
    }
    #shopify-section-{{ section.id }} .press__pubs { gap: 10px 18px; margin-bottom: 36px; }
  }
{% endstyle %}

<press-switcher class="press">
  <hr class="press__divider">

  {%- if section.settings.eyebrow != blank -%}
    <h3 class="press__eyebrow">{{ section.settings.eyebrow | escape }}</h3>
  {%- endif -%}

  <div class="press__grid">
    <div class="press__text">
      <div class="press__quotes" aria-live="polite">
        {%- for block in section.blocks -%}
          <p
            class="press__quote{% if forloop.first %} is-active{% endif %}"
            data-press-quote
            data-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >&ldquo;{{ block.settings.quote }}&rdquo;</p>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="press__pubs" role="group" aria-label="{{ section.settings.eyebrow | default: 'From the press' | escape }}">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="press__pub{% if forloop.first %} is-active{% endif %}"
              data-press-pub
              data-index="{{ forloop.index0 }}"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            >{{ block.settings.publication | escape }}</button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="press__image">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 960 }}"
          srcset="{{ section.settings.image | image_url: width: 480 }} 480w, {{ section.settings.image | image_url: width: 720 }} 720w, {{ section.settings.image | image_url: width: 960 }} 960w, {{ section.settings.image | image_url: width: 1200 }} 1200w"
          sizes="(min-width: 750px) 480px, 100vw"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
        >
      {%- else -%}
        <span class="press__placeholder" role="presentation"></span>
      {%- endif -%}
    </div>
  </div>
</press-switcher>

{% javascript %}
  class PressSwitcher extends HTMLElement {
    connectedCallback() {
      this.pubs = this.querySelectorAll('[data-press-pub]');
      this.quotes = this.querySelectorAll('[data-press-quote]');
      this.pubs.forEach((btn) => btn.addEventListener('click', () => this.activate(btn.dataset.index)));
    }

    activate(index) {
      this.pubs.forEach((btn) => {
        const active = btn.dataset.index === index;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      this.quotes.forEach((q) => q.classList.toggle('is-active', q.dataset.index === index));
    }
  }

  customElements.define('press-switcher', PressSwitcher);
{% endjavascript %}

{% schema %}
{
  "name": "Home: From the press",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the press" },
    { "type": "image_picker", "id": "image", "label": "Photo", "info": "Fixed — stays the same as the quote switches. Displays at 5:6." }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Press quote",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "info": "Quotation marks are added automatically." },
        { "type": "text", "id": "publication", "label": "Publication", "placeholder": "Esquire" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home: From the press",
      "blocks": [
        { "type": "quote", "settings": { "quote": "Less a calendar, more a piece of iconic design you can hang on your wall", "publication": "Esquire" } },
        { "type": "quote", "settings": { "quote": "A masterpiece of minimalism", "publication": "Elle" } },
        { "type": "quote", "settings": { "quote": "There's nothing quite like a massive, aesthetically pleasing wall calendar to signal that a new year is here.", "publication": "Vice Magazine" } },
        { "type": "quote", "settings": { "quote": "The Stendig Calendar is the perfect combination of form and function", "publication": "Daily Beast" } },
        { "type": "quote", "settings": { "quote": "Arguably the greatest calendar of all time", "publication": "Architect Magazine" } },
        { "type": "quote", "settings": { "quote": "Designers, architects and style gurus the world over are fans of this massive calendar", "publication": "The Independent" } }
      ]
    }
  ]
}
{% endschema %}
