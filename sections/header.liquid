<style>
  /* Stendig header — Asket-style text navigation
     Layout: [logo · Products]  ...  [Search · Cart (x)]
     All nav items are 14px text (1.4rem), matching product/section titles. */

  #shopify-section-{{ section.id }} .header {
    display: flex;
    /* Bottom-align so the nav/cart text sits on the logo's bottom edge */
    align-items: flex-end;
    gap: 3rem;
    /* !important beats base.css's forced 0 padding at >=990px */
    padding-top: 1.6rem !important;
    padding-bottom: 1.6rem !important;
  }

  /* Full-width anchor for the Products dropdown panel + sticky/transparent behaviour */
  .header-wrapper {
    position: relative;
    {% if section.settings.transparent-header %}background-color: transparent;{% endif %}
    transition: background-color 0.3s ease-in-out;
  }
  #shopify-section-{{ section.id }}.scrolled sticky-header { background-color: #ffffff; }
  {% if section.settings.enable_sticky_header %}
    .template-index #shopify-section-{{ section.id }} {
      position: sticky;
      top: 0;
      transform: unset !important;
      width: 100%;
    }
  {% endif %}
  {% if section.settings.transparent-header %}
    .template-index #shopify-section-{{ section.id }} sticky-header {
      position: absolute;
      width: 100%;
    }
  {% endif %}

  /* Logo, nav and utility are the three top-level items of the header.
     On desktop the nav's auto right-margin pushes utility to the right:
       [logo] [nav]  ........  [search cart]
     On mobile the nav is reordered to the far right, after the cart. */
  .st-header__nav {
    display: flex;
    align-items: flex-end;
    gap: 2.4rem;
    margin-right: auto;
  }
  .st-header__utility {
    display: flex;
    align-items: flex-end;
    gap: 2.4rem;
  }

  /* Logo wrappers are flex/flex-end and line-height 0 so the header aligns
     to the true bottom of the wordmark, not the font's line-box metrics. */
  .st-header__logo-h {
    display: flex;
    align-items: flex-end;
    margin: 0;
    line-height: 0;
  }
  .st-header__logo {
    display: flex;
    align-items: flex-end;
    line-height: 0;
    text-decoration: none;
    color: inherit;
    /* Baseline nudge — set from the theme editor (Logo vertical offset). */
    transform: translateY({{ section.settings.logo_offset_desktop | default: -4 }}px);
  }
  .st-header__logo-text {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.01em;
    color: inherit;
  }
  .st-header__logo .header__heading-logo { display: block; }

  .st-header__link {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    display: inline-block;
    padding: 0;
    white-space: nowrap;
  }
  .st-header__link:hover {
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }

  /* Strip the native <summary> disclosure marker */
  .header summary { list-style: none; cursor: pointer; }
  .header summary::-webkit-details-marker { display: none; }

  /* Full-width dropdown anchoring.
     Dawn sets `details-disclosure > details { position: relative }`, which
     clamps the panel to the width of "Products". Reset it so the panel
     anchors to the full-width .header-wrapper instead. */
  .st-products { display: inline-flex; align-items: center; }
  .st-products > details { position: static; display: inline-flex; align-items: center; }
  .st-products__summary { line-height: 1; padding: 0; }

  /* Cart label: keep "Cart (0)" as tight inline text */
  .st-header__cart { display: inline-block; }
  .st-header__cart-label { margin-right: 0.4rem; }

  /* Full-width dropdown panel */
  .st-products__panel {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    background: rgb(var(--color-background));
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.08);
    z-index: 4;
    max-height: 80vh;
    overflow-y: auto;
  }
  /* Columns pack from the left with full-height divider lines between them.
     Vertical padding lives on the columns so the dividers span the whole
     panel height, like Asket. */
  .st-products__panel-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
  }
  .st-products__col {
    flex: 0 0 25%;
    max-width: 25%;
    box-sizing: border-box;
    padding: 4rem 3.2rem;
    border-left: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }
  .st-products__col:first-child {
    border-left: none;
    padding-left: 0;
  }
  .st-products__heading {
    display: block;
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0;
    color: rgba(var(--color-foreground), 0.55);
    text-decoration: none;
    margin: 0 0 2rem;
  }
  a.st-products__heading:hover { color: rgb(var(--color-foreground)); }
  .st-products__list { margin: 0; padding: 0; }
  /* Font matches the product-card titles; item spacing matches Asket (8px) */
  .st-products__item {
    display: block;
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    padding: 0.8rem 0;
  }
  .st-products__item:hover {
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }

  /* Mobile: 12px gutters, hide Search, stack columns with rules between them */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .header {
      gap: 1.6rem;
      padding-top: 1.2rem;
      padding-bottom: 1.2rem;
    }
    .st-header__logo { transform: translateY({{ section.settings.logo_offset_mobile | default: -4 }}px); }
    .st-header__nav,
    .st-header__utility { gap: 1.6rem; }
    #shopify-section-{{ section.id }} .page-width {
      padding-left: 12px;
      padding-right: 12px;
    }
    .st-header__search { display: none; }

    /* Nav moves to the far right, after the cart:
         [logo] .......... [cart] [menu] */
    #shopify-section-{{ section.id }} .header > *:first-child { margin-right: auto; }
    .st-header__utility { order: 2; }
    .st-header__nav { order: 3; margin-right: 0; }
    .st-products__panel-inner {
      flex-direction: column;
      padding-top: 2.4rem;
      padding-bottom: 2.4rem;
    }
    .st-products__col {
      min-width: 0;
      padding: 0;
      border-left: none;
    }
    .st-products__col + .st-products__col {
      margin-top: 2.4rem;
      padding-top: 2.4rem;
      border-top: 0.1rem solid rgba(var(--color-foreground), 0.12);
    }
  }
</style>

