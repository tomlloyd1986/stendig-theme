<style>
  /* Stendig header — Asket-style text navigation
     Layout: [logo · Products]  ...  [Search · Cart (x)]
     All nav items are 14px text (1.4rem), matching product/section titles. */

  #shopify-section-{{ section.id }} .header {
    display: flex;
    /* Bottom-align so the nav/cart text sits on the logo's bottom edge */
    align-items: flex-end;
    gap: 3rem;
    /* !important beats base.css's forced 0 padding at >=990px */
    padding-top: 1.6rem !important;
    padding-bottom: 1.6rem !important;
  }

  /* ---- Ported from the header section's theme-editor Custom CSS, so that
     box can be safely emptied. Scoped to the section and placed after the
     base rule above so the outcome is identical to the editor version. ---- */
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .header {
      padding-top: 8px !important;
      padding-bottom: 8px !important;
    }
    #shopify-section-{{ section.id }} .header__heading-logo img {
      max-height: 36px !important;
    }
    #shopify-section-{{ section.id }} .header {
      padding-left: 20px !important;
      padding-right: 20px !important;
    }
  }
  #shopify-section-{{ section.id }} .header {
    max-width: 100% !important;
  }
  /* On mobile the side gutter is 12px (the Custom CSS previously forced 20px
     at every width, quietly overriding the intended mobile gutter). */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .header {
      padding-left: 12px !important;
      padding-right: 12px !important;
    }
  }
  /* ---- end ported Custom CSS ---- */

  /* Mobile only (<=749px): extend the white bar below the content. The
     .header.st-header selector out-specifies the base `.header` rule above
     (which is !important at all widths); the media query keeps desktop
     exactly as-is. */
  @media screen and (max-width: 749px) {
    /* [data-sticky] is on the header wrapper; including it lifts specificity
       above the theme Custom CSS rule
       `.template-index #shopify-section-header [data-sticky=true] > header`
       which otherwise caps the home-page mobile bar at 10px !important. */
    #shopify-section-{{ section.id }} [data-sticky] > header.header.st-header {
      padding-bottom: 1.8rem !important;
    }
  }

  /* Full-width anchor for the Products dropdown panel + sticky/transparent behaviour.
     z-index keeps the (opaque) header bar above the menu drawer, so the logo
     and Close trigger stay visible while the drawer is open. */
  .header-wrapper {
    position: relative;
    z-index: 30;
    {% if section.settings.transparent-header %}background-color: transparent;{% endif %}
    transition: background-color 0.3s ease-in-out;
  }
  body.st-drawer-open .header-wrapper { background-color: rgb(var(--color-background)); }
  #shopify-section-{{ section.id }}.scrolled sticky-header { background-color: #ffffff; }
  {% if section.settings.enable_sticky_header %}
    .template-index #shopify-section-{{ section.id }} {
      position: sticky;
      top: 0;
      transform: unset !important;
      width: 100%;
    }
  {% endif %}
  {% if section.settings.transparent-header %}
    .template-index #shopify-section-{{ section.id }} sticky-header {
      position: absolute;
      width: 100%;
    }
  {% endif %}

  /* Logo, nav and utility are the three top-level items of the header.
     On desktop the nav's auto right-margin pushes utility to the right:
       [logo] [nav]  ........  [search cart]
     On mobile the nav is reordered to the far right, after the cart. */
  .st-header__nav {
    display: flex;
    align-items: flex-end;
    gap: 2.4rem;
    margin-right: auto;
  }
  .st-header__utility {
    display: flex;
    align-items: flex-end;
    gap: 2.4rem;
  }
  /* Vertical nudge for the nav/cart text — set from the theme editor.
     Negative moves them up to sit on the logo's bottom edge. */
  .st-header__nav,
  .st-header__utility {
    transform: translateY({{ section.settings.nav_offset_desktop | default: 0 }}px);
  }

  /* Logo wrappers are flex/flex-end and line-height 0 so the header aligns
     to the true bottom of the wordmark, not the font's line-box metrics. */
  .st-header__logo-h {
    display: flex;
    align-items: flex-end;
    margin: 0;
    line-height: 0;
  }
  .st-header__logo {
    display: flex;
    align-items: flex-end;
    line-height: 0;
    text-decoration: none;
    color: inherit;
  }
  .st-header__logo-text {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.01em;
    color: inherit;
  }
  .st-header__logo .header__heading-logo { display: block; }

  .st-header__link {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    display: inline-block;
    padding: 0;
    white-space: nowrap;
  }
  .st-header__link:hover {
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }

  /* Strip the native <summary> disclosure marker */
  .header summary { list-style: none; cursor: pointer; }
  .header summary::-webkit-details-marker { display: none; }

  /* Cart label: keep "Cart (0)" as tight inline text */
  .st-header__cart { display: inline-block; }
  .st-header__cart-label { margin-right: 0.4rem; }

  /* ===== Menu drawer (left slide-out) ===== */
  .st-drawer-root { display: block; }
  /* --st-header-bottom is the header's bottom edge in px, set in JS on open,
     so the drawer and overlay sit below the header bar instead of over it. */
  .st-drawer__overlay {
    position: fixed;
    inset: 0;
    background: rgba(var(--color-foreground), 0.4);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 20;
  }
  .st-drawer {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    height: 100dvh;
    width: 40rem;            /* desktop: a single column */
    max-width: 100vw;
    box-sizing: border-box;
    background: rgb(var(--color-background));
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 21;
    overflow-y: auto;
    /* Content clears the header, which sits on top via z-index (extra
       buffer so the first heading is never tucked under the bar). */
    padding: calc(var(--st-header-bottom, 8rem) + 8rem) 2.4rem 2.4rem;
    display: flex;
    flex-direction: column;
  }
  .st-drawer-root.is-open .st-drawer { transform: translateX(0); }
  .st-drawer-root.is-open .st-drawer__overlay { opacity: 1; visibility: visible; }

  @media screen and (max-width: 749px) {
    .st-drawer { width: 100vw; }   /* mobile: whole screen */
  }

  /* Desktop: underline the trigger while the drawer is open */
  @media screen and (min-width: 750px) {
    .st-drawer__toggle[aria-expanded="true"] {
      text-decoration: underline;
      text-underline-offset: 0.3rem;
    }
  }

  /* The trigger shows "Collection" by default; on mobile it becomes
     "Close x" while the drawer is open, and the cart is hidden. */
  .st-drawer__toggle-close { display: none; align-items: center; gap: 0.5rem; }
  .st-drawer__toggle-x { width: 1rem; height: 1rem; }
  @media screen and (max-width: 749px) {
    .st-drawer__toggle[aria-expanded="true"] .st-drawer__toggle-open { display: none; }
    .st-drawer__toggle[aria-expanded="true"] .st-drawer__toggle-close { display: inline-flex; }
    body.st-drawer-open .st-header__cart { display: none; }
  }

  .st-drawer__group + .st-drawer__group { margin-top: 3.2rem; }
  .st-drawer__heading {
    display: block;
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0;
    color: rgba(var(--color-foreground), 0.55);
    text-decoration: none;
    margin: 0 0 1.2rem;
  }
  a.st-drawer__heading:hover { color: rgb(var(--color-foreground)); }
  .st-drawer__list { margin: 0; padding: 0; }
  /* Font matches the product-card titles; item spacing matches Asket (8px) */
  .st-drawer__item {
    display: block;
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    padding: 0.8rem 0;
  }
  .st-drawer__item:hover {
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }

  /* Mobile: 12px gutters, hide Search, stack columns with rules between them */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .header {
      gap: 1.6rem;
      padding-top: 2rem;
      padding-bottom: 2.8rem;
    }
    .st-header__nav,
    .st-header__utility {
      gap: 1.6rem;
      transform: translateY({{ section.settings.nav_offset_mobile | default: 0 }}px);
    }
    #shopify-section-{{ section.id }} .page-width {
      padding-left: 12px;
      padding-right: 12px;
    }
    .st-header__search { display: none; }

    /* Nav moves to the far right, after the cart:
         [logo] .......... [cart] [menu] */
    #shopify-section-{{ section.id }} .header > *:first-child { margin-right: auto; }
    .st-header__utility { order: 2; }
    .st-header__nav { order: 3; margin-right: 0; }
  }
</style>

<script src="{{ 'details-disclosure.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'details-modal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

<svg xmlns="http://www.w3.org/2000/svg" class="hidden">
  <symbol id="icon-search" viewbox="0 0 18 19" fill="none">
    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.03 11.68A5.784 5.784 0 112.85 3.5a5.784 5.784 0 018.18 8.18zm.26 1.12a6.78 6.78 0 11.72-.7l5.4 5.4a.5.5 0 11-.71.7l-5.41-5.4z" fill="currentColor"/>
  </symbol>

  <symbol id="icon-close" class="icon icon-close" fill="none" viewBox="0 0 18 17">
    <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor">
  </symbol>
</svg>

<{% if section.settings.enable_sticky_header %}sticky-header{% else %}div{% endif %} class="header-wrapper transparent-header color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}" data-sticky="{{ section.settings.enable_sticky_header }}">
  <header class="header page-width st-header">
    {%- comment -%} Logo {%- endcomment -%}
      {%- if request.page_type == 'index' -%}<h1 class="header__heading st-header__logo-h">{%- endif -%}
        <a href="{{ routes.root_url }}" class="header__heading-link st-header__logo link link--text focus-inset">
          {%- if section.settings.logo != blank -%}
            {%- assign image_size = section.settings.logo_width | append: 'x' -%}
            {%- if section.settings.altlogo.src != blank and section.settings.transparent-header -%}
              <img srcset="{{ section.settings.altlogo | img_url: image_size }} 1x, {{ section.settings.altlogo | img_url: image_size, scale: 2 }} 2x"
                src="{{ section.settings.altlogo | img_url: image_size }}"
                loading="lazy"
                class="header__heading-logo altlogo"
                width="{{ section.settings.altlogo.width }}"
                height="{{ section.settings.altlogo.height }}"
                alt="{{ section.settings.altlogo.alt | default: shop.name | escape }}"
              >
            {%- endif -%}
            <img srcset="{{ section.settings.logo | img_url: image_size }} 1x, {{ section.settings.logo | img_url: image_size, scale: 2 }} 2x"
              src="{{ section.settings.logo | img_url: image_size }}"
              loading="lazy"
              class="header__heading-logo"
              width="{{ section.settings.logo.width }}"
              height="{{ section.settings.logo.height }}"
              alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            >
          {%- else -%}
            <span class="st-header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      {%- if request.page_type == 'index' -%}</h1>{%- endif -%}

      {%- comment -%} Menu trigger — opens the left slide-out drawer {%- endcomment -%}
      <nav class="st-header__nav">
        {%- if section.settings.products_menu != blank and section.settings.products_menu.links.size > 0 -%}
          <button
            type="button"
            class="st-header__link st-drawer__toggle focus-inset"
            aria-haspopup="dialog"
            aria-expanded="false"
            aria-label="{{ section.settings.products_label | default: 'Collection' | escape }}"
            aria-controls="StDrawer-{{ section.id }}"
          ><span class="st-drawer__toggle-open">{{ section.settings.products_label | default: 'Collection' | escape }}</span><span class="st-drawer__toggle-close" aria-hidden="true">{{ 'accessibility.close' | t }} <svg class="icon icon-close st-drawer__toggle-x" aria-hidden="true" focusable="false" viewBox="0 0 18 17"><use href="#icon-close"></svg></span></button>
        {%- endif -%}
      </nav>

    <div class="st-header__utility">
      {%- comment -%} Search — text trigger, hidden on mobile {%- endcomment -%}
      <details-modal class="header__search st-header__search">
        <details>
          <summary class="st-header__link focus-inset" aria-haspopup="dialog" aria-label="{{ 'general.search.search' | t }}">
            {{ 'general.search.search' | t }}
          </summary>
          <div class="search-modal modal__content" role="dialog" aria-modal="true" aria-label="{{ 'general.search.search' | t }}">
            <div class="modal-overlay"></div>
            <div class="search-modal__content" tabindex="-1">
              {%- if settings.predictive_search_enabled -%}
                <predictive-search class="search-modal__form" data-loading-text="{{ 'accessibility.loading' | t }}">
              {%- endif -%}
                <form action="{{ routes.search_url }}" method="get" role="search" class="search search-modal__form">
                  <div class="field">
                    <input class="search__input field__input"
                      id="Search-In-Modal"
                      type="search"
                      name="q"
                      value=""
                      placeholder="{{ 'general.search.search' | t }}"
                      {%- if settings.predictive_search_enabled -%}
                        role="combobox"
                        aria-expanded="false"
                        aria-owns="predictive-search-results-list"
                        aria-controls="predictive-search-results-list"
                        aria-haspopup="listbox"
                        aria-autocomplete="list"
                        autocorrect="off"
                        autocomplete="off"
                        autocapitalize="off"
                        spellcheck="false"
                      {%- endif -%}
                    >
                    <label class="field__label" for="Search-In-Modal">{{ 'general.search.search' | t }}</label>
                    <input type="hidden" name="options[prefix]" value="last">
                    <button class="search__button field__button" aria-label="{{ 'general.search.search' | t }}">
                      <svg class="icon icon-search" aria-hidden="true" focusable="false" role="presentation">
                        <use href="#icon-search">
                      </svg>
                    </button>
                  </div>

                  {%- if settings.predictive_search_enabled -%}
                    <div class="predictive-search predictive-search--header" tabindex="-1" data-predictive-search>
                      <div class="predictive-search__loading-state">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                        </svg>
                      </div>
                    </div>

                    <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
                  {%- endif -%}
                </form>
              {%- if settings.predictive_search_enabled -%}
                </predictive-search>
              {%- endif -%}
              <button type="button" class="search-modal__close-button modal__close-button link link--text focus-inset" aria-label="{{ 'accessibility.close' | t }}">
                <svg class="icon icon-close" aria-hidden="true" focusable="false" role="presentation">
                  <use href="#icon-close">
                </svg>
              </button>
            </div>
          </div>
        </details>
      </details-modal>

      {%- comment -%} Cart with live "(x)" count {%- endcomment -%}
      <a href="{{ routes.cart_url }}" class="st-header__link st-header__cart focus-inset" id="cart-icon-bubble">
        {%- render 'cart-count' -%}
      </a>
    </div>
  </header>
</{% if section.settings.enable_sticky_header %}sticky-header{% else %}div{% endif %}>

{%- comment -%}
  Left slide-out menu drawer. Rendered outside the header so it is not
  trapped by the header/nav transforms (a transformed ancestor would make
  position:fixed relative to it instead of the viewport).
{%- endcomment -%}
{%- if section.settings.products_menu != blank and section.settings.products_menu.links.size > 0 -%}
  <st-drawer id="StDrawer-{{ section.id }}" class="st-drawer-root">
    <div class="st-drawer__overlay" role="presentation"></div>
    <aside class="st-drawer" role="dialog" aria-modal="true" aria-label="{{ section.settings.products_label | default: 'Collection' | escape }}">
      <nav class="st-drawer__menu">
        {%- for link in section.settings.products_menu.links -%}
          <div class="st-drawer__group">
            {%- if link.links != blank -%}
              <a href="{{ link.url }}" class="st-drawer__heading"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>
              <ul class="st-drawer__list list-unstyled" role="list">
                {%- for childlink in link.links -%}
                  <li>
                    <a href="{{ childlink.url }}" class="st-drawer__item"{% if childlink.current %} aria-current="page"{% endif %}>{{ childlink.title | escape }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <a href="{{ link.url }}" class="st-drawer__heading"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </nav>
    </aside>
  </st-drawer>
{%- endif -%}

{%- render 'cart-notification', color_scheme: section.settings.color_scheme -%}

{% javascript %}
  class StickyHeader extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.header = document.getElementById('shopify-section-header');
      this.headerBounds = {};
      this.currentScrollTop = 0;
      this.preventReveal = false;
      this.predictiveSearch = this.querySelector('predictive-search');

      this.onScrollHandler = this.onScroll.bind(this);
      this.hideHeaderOnScrollUp = () => this.preventReveal = true;

      this.addEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.addEventListener('scroll', this.onScrollHandler, false);

      this.createObserver();
    }

    disconnectedCallback() {
      this.removeEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.removeEventListener('scroll', this.onScrollHandler);
    }

    createObserver() {
      let observer = new IntersectionObserver((entries, observer) => {
        this.headerBounds = entries[0].intersectionRect;
        observer.disconnect();
      });

      observer.observe(this.header);
    }

    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      if (this.predictiveSearch && this.predictiveSearch.isOpen) return;

      if (scrollTop > this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        requestAnimationFrame(this.hide.bind(this));
      } else if (scrollTop < this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        if (!this.preventReveal) {
          requestAnimationFrame(this.reveal.bind(this));
        } else {
          window.clearTimeout(this.isScrolling);

          this.isScrolling = setTimeout(() => {
            this.preventReveal = false;
          }, 66);

          requestAnimationFrame(this.hide.bind(this));
        }
      } else if (scrollTop <= this.headerBounds.top) {
        requestAnimationFrame(this.reset.bind(this));
      }

      this.currentScrollTop = scrollTop;
    }

    hide() {
      this.header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
      this.closeMenuDisclosure();
      this.closeSearchModal();
    }

    reveal() {
      this.header.classList.add('shopify-section-header-sticky', 'animate');
      this.header.classList.remove('shopify-section-header-hidden');
    }

    reset() {
      this.header.classList.remove('shopify-section-header-hidden', 'shopify-section-header-sticky', 'animate');
    }

    closeMenuDisclosure() {
      this.disclosures = this.disclosures || this.header.querySelectorAll('details-disclosure');
      this.disclosures.forEach(disclosure => disclosure.close());
    }

    closeSearchModal() {
      this.searchModal = this.searchModal || this.header.querySelector('details-modal');
      if (this.searchModal) this.searchModal.close(false);
    }

  }

  customElements.define('sticky-header', StickyHeader);

  class StDrawer extends HTMLElement {
    connectedCallback() {
      this.overlay = this.querySelector('.st-drawer__overlay');
      this.toggle = document.querySelector('[aria-controls="' + this.id + '"]');

      if (this.toggle) this.toggle.addEventListener('click', (e) => {
        e.preventDefault();
        this.classList.contains('is-open') ? this.close() : this.open();
      });
      if (this.overlay) this.overlay.addEventListener('click', () => this.close());

      this.onKeydown = (e) => { if (e.key === 'Escape') this.close(); };
    }

    open() {
      // Offset the drawer to sit below the header bar. offsetHeight is the
      // bar's rendered height (scroll-independent), set on :root so the
      // fixed drawer/overlay reliably inherit it.
      const bar = document.querySelector('.header-wrapper');
      const offset = bar ? bar.offsetHeight : 0;
      document.documentElement.style.setProperty('--st-header-bottom', offset + 'px');

      this.classList.add('is-open');
      if (this.toggle) this.toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('overflow-hidden', 'st-drawer-open');
      document.addEventListener('keydown', this.onKeydown);
      const first = this.querySelector('.st-drawer a, .st-drawer button');
      if (first) first.focus();
    }

    close() {
      this.classList.remove('is-open');
      if (this.toggle) this.toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('overflow-hidden', 'st-drawer-open');
      document.removeEventListener('keydown', this.onKeydown);
      if (this.toggle) this.toggle.focus();
    }
  }

  customElements.define('st-drawer', StDrawer);
{% endjavascript %}

<script defer="defer">
  {% if section.settings.enable_sticky_header %}
    const header = document.querySelector(".template-index #shopify-section-{{ section.id }}")

    document.addEventListener('scroll', function() {
      let root = document.documentElement;
      const scrollTop = document.body.scrollTop || document.documentElement.scrollTop
      const percentage = scrollTop / 100;
      const fixed = percentage.toFixed(2);

      document.querySelector("#shopify-section-{{ section.id }}").classList.toggle("scrolled", scrollTop > 10);
    })
  {% endif %}

  /* Keep --st-header-bottom (menu drawer offset) in sync with the header
     height at all times, so the drawer always opens below the bar. */
  (function () {
    function updateHeaderBottom() {
      var bar = document.querySelector('.header-wrapper');
      if (bar) {
        document.documentElement.style.setProperty('--st-header-bottom', bar.offsetHeight + 'px');
      }
    }
    updateHeaderBottom();
    document.addEventListener('DOMContentLoaded', updateHeaderBottom);
    window.addEventListener('load', updateHeaderBottom);
    window.addEventListener('resize', updateHeaderBottom);
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(updateHeaderBottom);
  })();
</script>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if section.settings.logo %}
      {% assign image_size = section.settings.logo.width | append: 'x' %}
      "logo": {{ section.settings.logo | img_url: image_size | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ shop.url | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = shop.url | append: routes.search_url | append: "?q={search_term_string}" %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ shop.url | append: page.url | json }}
    }
  </script>
{%- endif -%}

