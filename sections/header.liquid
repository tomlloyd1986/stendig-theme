{% style %}
  {% if section.settings.transparent-header %}
    .template-index #shopify-section-{{ section.id }}:not(.scrolled) .st-header__link,
    .template-index #shopify-section-{{ section.id }}:not(.scrolled) .st-header__logo-text {
      color: {{ section.settings.transparent-color }}
    }
  {% endif %}
{% endstyle %}
