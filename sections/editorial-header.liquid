{% comment %}
  Editorial header — reusable page header in the 2026 Collection style.
  Blocks (add/remove/reorder in the editor): Heading, Text, Divider.
  With both a Heading and a Text block present, they sit side by side
  from 750px (heading left, text right); either alone runs full width.
  Type and spacing values mirror the live PageFly range page.
{% endcomment %}

{%- liquid
  assign has_heading = false
  assign has_text = false
  for block in section.blocks
    if block.type == 'heading'
      assign has_heading = true
    elsif block.type == 'text'
      assign has_text = true
    endif
  endfor
-%}

{% style %}
  #shopify-section-{{ section.id }} .edh { padding-top: {{ section.settings.space_above }}px; }
  #shopify-section-{{ section.id }} .edh__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.4rem;
    align-items: start;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .edh__head--split {
      grid-template-columns: 1fr 1fr;
      column-gap: 6rem;
    }
  }
  #shopify-section-{{ section.id }} .edh__heading {
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.3;
    font-weight: 400;
    margin: 0;
    color: #000;
  }
  #shopify-section-{{ section.id }} .edh__text {
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.5;
    letter-spacing: 0;
    color: #000;
  }
  #shopify-section-{{ section.id }} .edh__text p { margin: 0 0 1em; }
  #shopify-section-{{ section.id }} .edh__text p:last-child { margin-bottom: 0; }
  #shopify-section-{{ section.id }} .edh__divider {
    border: none;
    border-top: 2px solid #d4d4d4;
    margin: {{ section.settings.space_above_divider }}px 0 {{ section.settings.space_below_divider }}px;
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .page-width { padding-left: 12px; padding-right: 12px; }
  }
{% endstyle %}

<div class="edh page-width">
  {%- if has_heading or has_text -%}
    <div class="edh__head{% if has_heading and has_text %} edh__head--split{% endif %}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2 class="edh__heading" {{ block.shopify_attributes }}>{{ block.settings.heading }}</h2>
          {%- when 'text' -%}
            <div class="edh__text rte" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- if block.type == 'divider' -%}
      <hr class="edh__divider" {{ block.shopify_attributes }}>
    {%- endif -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Editorial header",
  "settings": [
    { "type": "range", "id": "space_above", "label": "Space above", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 20, "max": 56, "step": 2, "unit": "px", "default": 32 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 12, "max": 20, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "space_above_divider", "label": "Space above divider", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "space_below_divider", "label": "Space below divider", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 40 }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Heading" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Pair text with a heading to introduce the page.</p>" }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "limit": 1,
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Editorial header",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "divider" }
      ]
    }
  ]
}
{% endschema %}
