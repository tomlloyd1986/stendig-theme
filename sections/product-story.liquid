{% comment %}
  Product: Story — native rebuild of the PageFly editorial section on the
  product pages ("If you do it right, it will last forever", "Space and
  scale", "New year, new colour"…). A stack of two block types:
    Text — centred column (max 550px) with a Display-Light heading and a
           14px paragraph.
    Images — one full-width image, or two side by side (10px gap),
             natural aspect ratio.
  Editable: block order and content. Type, widths and spacing locked.
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} .pst {
    padding: 0 20px 40px;
  }
  #shopify-section-{{ section.id }} .pst__text {
    max-width: 550px;
    margin: 0 auto;
    padding: 40px 0;
  }
  #shopify-section-{{ section.id }} .pst__heading {
    font-family: "Neue Haas Grotesk Display", var(--font-heading-family), sans-serif;
    font-size: 32px;
    line-height: 1.2;
    font-weight: 400;
    letter-spacing: 0;
    color: #000;
    margin: 0 0 14px;
  }
  #shopify-section-{{ section.id }} .pst__body {
    font-family: var(--font-body-family);
    font-size: 14px;
    line-height: 21px;
    font-weight: 400;
    letter-spacing: 0;
    color: #121212;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .pst__images {
    display: flex;
    gap: 10px;
    margin: 0 0 10px;
  }
  #shopify-section-{{ section.id }} .pst__images > div {
    flex: 1 1 0;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .pst__images img {
    display: block;
    width: 100%;
    height: auto;
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .pst { padding-left: 12px; padding-right: 12px; }
    #shopify-section-{{ section.id }} .pst__text { padding: 20px 0 40px; }
    #shopify-section-{{ section.id }} .pst__heading { font-size: 22px; }
    #shopify-section-{{ section.id }} .pst__body { font-size: 13px; }
    #shopify-section-{{ section.id }} .pst__images { gap: 5px; margin-bottom: 5px; }
  }
{% endstyle %}

<div class="pst">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'text' -%}
        <div class="pst__text" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2 class="pst__heading">{{ block.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <p class="pst__body">{{ block.settings.body }}</p>
          {%- endif -%}
        </div>
      {%- when 'images' -%}
        <div class="pst__images" {{ block.shopify_attributes }}>
          {%- if block.settings.image_1 != blank -%}
            <div>
              <img
                src="{{ block.settings.image_1 | image_url: width: 1200 }}"
                srcset="{{ block.settings.image_1 | image_url: width: 750 }} 750w, {{ block.settings.image_1 | image_url: width: 1200 }} 1200w, {{ block.settings.image_1 | image_url: width: 1600 }} 1600w"
                sizes="{% if block.settings.image_2 != blank %}(min-width: 750px) 50vw, 100vw{% else %}100vw{% endif %}"
                width="{{ block.settings.image_1.width }}"
                height="{{ block.settings.image_1.height }}"
                alt="{{ block.settings.image_1.alt | escape }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}
          {%- if block.settings.image_2 != blank -%}
            <div>
              <img
                src="{{ block.settings.image_2 | image_url: width: 1200 }}"
                srcset="{{ block.settings.image_2 | image_url: width: 750 }} 750w, {{ block.settings.image_2 | image_url: width: 1200 }} 1200w, {{ block.settings.image_2 | image_url: width: 1600 }} 1600w"
                sizes="(min-width: 750px) 50vw, 100vw"
                width="{{ block.settings.image_2.width }}"
                height="{{ block.settings.image_2.height }}"
                alt="{{ block.settings.image_2.alt | escape }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}
        </div>
    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Product: Story",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "body", "label": "Text" }
      ]
    },
    {
      "type": "images",
      "name": "Images",
      "settings": [
        { "type": "image_picker", "id": "image_1", "label": "Image" },
        { "type": "image_picker", "id": "image_2", "label": "Second image", "info": "Optional. When set, the two images sit side by side." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product: Story",
      "blocks": [
        { "type": "text" },
        { "type": "images" }
      ]
    }
  ]
}
{% endschema %}
