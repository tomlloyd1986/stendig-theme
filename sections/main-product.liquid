<script>
  let var_sel = document.querySelector("variant-radios");

  function hideBody() {
    let body = document.querySelector("body");
    body.classList.add("show_body_V_pro");
  }

  const productOptions = {{ product.options_with_values | json }};
  const colorOptionMeta = (() => {
    const match = productOptions.find((option) => {
      const name = option.name.toLowerCase();
      return name.includes("color") || name.includes("colour");
    });

    if (match) {
      return {
        name: match.name,
        index: productOptions.indexOf(match) + 1,
        enabled: true
      };
    }

    return {
      name: null,
      index: null,
      enabled: false
    };
  })();

  const updateThumbnails = (targetProduct, colorValue) => {
    if (!targetProduct) return;

    const prdThumbnails = targetProduct.querySelectorAll(
      ".product__media-wrapper .product__media-item"
    );
    const selectedColor = (colorValue || "").trim().toLowerCase();
    let firstVisible = false;

    prdThumbnails.forEach((curImg) => {
      const mediaAlt =
        (curImg.dataset.mediaAlt ||
          curImg.querySelector("img")?.alt ||
          "").trim().toLowerCase();

      const isMatch = selectedColor ? mediaAlt.includes(selectedColor) : true;

      if (isMatch) {
        curImg.style.display = "block";
        if (!firstVisible) {
          curImg.classList.add("display-block");
          firstVisible = true;
        } else {
          curImg.classList.remove("display-block");
        }
      } else {
        curImg.style.display = "none";
        curImg.classList.remove("display-block");
      }
    });
  };

  document.addEventListener("DOMContentLoaded", () => {
    const selected_prd = {{ product.selected_or_first_available_variant | json }};

    if (!colorOptionMeta.enabled) {
      hideBody();
      return;
    }

    const colorOptionName = colorOptionMeta.name;

    if (window.location.pathname.includes("/products")) {
      const colorValue = selected_prd[`option${colorOptionMeta.index}`];
      const product = document.querySelector(".product");
      updateThumbnails(product, colorValue);
    }

    document.addEventListener("change", (e) => {
      const target = e.target;

      if (target.matches(`input[name="${colorOptionName}"]`)) {
        const closestProduct = target.closest(".product");
        updateThumbnails(closestProduct, target.value);
      }
    });

    hideBody();
  });

  document.addEventListener("click", (e) => {
    const target = e.target;

    // console.log('Waiting List', target);

    if (
      target.closest(".join-waitlist-btn-custom") ||
      target.classList.contains("join-waitlist-btn-custom")
    ) {
      wisepops('event', 'joinwaitlist_vcal');
      wisepops(
        "event",
        "joinwaitlist_vcal"
      );
      {% comment %} console.log("click waiting List email popup"); {% endcomment %}

      let wiseWaitPop = document.querySelectorAll("#wisepops-instance-505943");
      if (wiseWaitPop) {
        wiseWaitPop.forEach((e) => {
          let wiseWaitPopShadow = e.shadowRoot;
          let btn = wiseWaitPopShadow.querySelector(
            'button[aria-labelledby="wisepops-tab-label-505943"]'
          );
          {% comment %} console.log("wisePOP Shadow Root", btn); {% endcomment %}
          btn.click();
        });
      }
    }

    if (target.closest(".ctm_buy_it_now")) {
      document
        .querySelector(
          '.shopify-payment-button__button.shopify-payment-button__button--branded [role="button"]'
        )
        .click();
    }
  }); 
  {% comment %} if (typeof var_sel !== 'undefined' && var_sel) {
      var_sel.addEventListener("change", () => {
        VariantAvailability();
      });
  } {% endcomment %}

</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const variantRadios = document.querySelector('variant-radios[data-section="{{ section.id }}"]');
    if (!variantRadios) return;

    const variantDataNode = variantRadios.querySelector('script[type="application/json"]');
    if (!variantDataNode) return;

    let variantData = [];
    try {
      variantData = JSON.parse(variantDataNode.textContent || '[]');
    } catch (error) {
      return;
    }

    if (!Array.isArray(variantData) || !variantData.length) return;

    const fieldsets = Array.from(variantRadios.querySelectorAll('fieldset'));
    if (!fieldsets.length) return;
    const marketList = Array.isArray(window.marketAvailability) ? window.marketAvailability : [];
    const currentDomain = window.location.host.toLowerCase();

    function isVariantAvailableForCurrentMarket(variant) {
      if (!variant) return false;

      const warehouseDecision = window.warehouseAvailability ? window.warehouseAvailability(variant.id) : null;
      if (warehouseDecision !== null) return warehouseDecision;

      if (!marketList.length) return Boolean(variant.available);

      const matchedVariant = marketList.find((marketVariant) => {
        const sameVariant = String(marketVariant.variant_id) === String(variant.id);
        let marketDomain = marketVariant.domain ? String(marketVariant.domain).toLowerCase() : '';

        if (marketVariant.market && String(marketVariant.market).toLowerCase() === 'gb') {
          marketDomain = 'stendigcalendars.com';
        }

        return sameVariant && marketDomain === currentDomain;
      });

      if (!matchedVariant) return Boolean(variant.available);
      return Number(matchedVariant.qty) > 0;
    }

    function syncUnavailableVariantLabels() {
      const selectedValues = fieldsets.map((fieldset) => {
        const checkedInput = fieldset.querySelector('input[type="radio"]:checked');
        return checkedInput ? checkedInput.value : null;
      });

      fieldsets.forEach((fieldset, fieldsetIndex) => {
        const radios = Array.from(fieldset.querySelectorAll('input[type="radio"]'));

        radios.forEach((radio) => {
          const label = variantRadios.querySelector(`label[for="${radio.id.replace(/"/g, '\\"')}"]`);
          if (!label) return;

          const matchingVariants = variantData.filter((variant) => {
            if (!Array.isArray(variant.options)) return false;

            return variant.options.every((optionValue, optionIndex) => {
              if (optionIndex === fieldsetIndex) {
                return optionValue === radio.value;
              }

              const selectedValue = selectedValues[optionIndex];
              return selectedValue ? optionValue === selectedValue : true;
            });
          });

          const isUnavailable =
            matchingVariants.length === 0 || !matchingVariants.some((variant) => isVariantAvailableForCurrentMarket(variant));

          label.classList.toggle('var_label_disabled', isUnavailable);
        });
      });
    }

    syncUnavailableVariantLabels();
    setTimeout(syncUnavailableVariantLabels, 120);
    setTimeout(syncUnavailableVariantLabels, 320);
    variantRadios.addEventListener('change', () => {
      window.requestAnimationFrame(syncUnavailableVariantLabels);
    });
  });
</script>
