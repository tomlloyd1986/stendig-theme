  {% comment %} function VariantAvailability( return_flag_only = false){
    let dis_var_raw = "{{ variant_disabled }}";
    // Build an array of disabled base colors (e.g., ["red","black"]) from Liquid
    let disabledColors = (dis_var_raw || "")
      .split(",")
      .map(s => s.trim().toLowerCase())
      .filter(Boolean);

    let qty_sel = document.querySelector('.product-form__quantity')
    let buy_btns = document.querySelector('.product-form__buttons');

    let Red = [ "紅色的", "rød", "rood", "rouge", "rot", "rosso", "rossa", "빨간색", "roja", "rojo", "red" ];
    let White = [ "blanca", "blanco", "하얀색", "bianca", "bianco", "weiß", "blanche", "blanc", "wit", "hvid", "白色的", "white" ];
    let Black = [ "黑色的", "sort", "zwart", "schwarz", "nero", "nera", "noir", "noire", "검은색", "negro", "negra", "black" ];
    let Yellow = [ "黃色的", "gul", "geel", "gelb", "giallo", "gialla", "jaune", "노란색", "amarillo", "amarilla", "yellow" ];
    let varColor;
    let colorFlag;

    return new Promise( res => {
      setTimeout(() => { 
      
        // var_sel.querySelectorAll('label.var_label_disabled').forEach( e => e.classList.remove('var_label_disabled'));
        varColor = getColourFromUrl();
  
        if(Black.includes(varColor)){ colorFlag = 'black'; }
        if(Red.includes(varColor)){ colorFlag = 'red'; }
        if(White.includes(varColor)){ colorFlag = 'white'; }
        if(Yellow.includes(varColor)){ colorFlag = 'yellow'; }
  
        if(return_flag_only){ res (disabledColors.includes(colorFlag)) }
        else{

          // Match variant inputs by case-insensitive contains to be resilient to suffixes like "Black – 2025"
          function disableVar(aliasList){
            // Get color option name dynamically - works for all languages including Chinese
            const colorOptionName = {{ product.options_with_values.first.name | json }};
            const inputs = Array.from(document.querySelectorAll(`[name="${colorOptionName}"]`));
            const aliases = aliasList.map(x => String(x).toLowerCase());
            inputs.forEach(inp => {
              const val = (inp.value || '').toLowerCase();
              if (aliases.some(a => val === a || val.includes(a))) {
                const label = inp.closest('fieldset')?.querySelector(`label[for="${inp.id}"]`);
                if (label && !label.classList.contains('var_label_disabled')) {
                  label.classList.add('var_label_disabled');
                }
              }
            });
          }

          // Clear previous disabled marks to avoid stale state
          document.querySelectorAll('label.var_label_disabled').forEach(l => l.classList.remove('var_label_disabled'));

          // Debug current disabled colors from metafield
          try { console.log('disabledColors:', disabledColors); } catch(e){}

          // Disable all color groups that appear in disabledColors
          if (disabledColors.includes('black')) { disableVar(Black) }
          if (disabledColors.includes('red')) { disableVar(Red) }
          if (disabledColors.includes('white')) { disableVar(White) }
          if (disabledColors.includes('yellow')) { disableVar(Yellow) }

          if( disabledColors.includes(colorFlag) ){
            qty_sel.style.display = 'none';
            buy_btns.querySelector('.product-form__submit[type="submit"]').style.display = 'none';
            buy_btns.querySelector('.ctm_buy_it_now').style.display = 'none';
            buy_btns.querySelector('.shopify-payment-button').style.display = "none";
            buy_btns.querySelector('.for_var_dsabled').style.display = 'flex';
            showSoldOutOnVarChange(true)
          }else{

            qty_sel.style.display = 'block';
            buy_btns.querySelector('.product-form__submit[type="submit"]').style.display = 'flex';
            buy_btns.querySelector('.ctm_buy_it_now').style.display = 'flex';
            buy_btns.querySelector('.shopify-payment-button').style.display = "block";
            buy_btns.querySelector('.for_var_dsabled').style.display = 'none';
            showSoldOutOnVarChange(false)
          }
  
        }

        {% comment %} console.log('varColor ' + varColor + ' disabledColors ' + disabledColors.join(',')); {% endcomment %}

      }, 0);
    })

  } {% endcomment %}

