{% comment %} ---------------------- Delivery Dates and market based Join waitlist logic ---------------------- {% endcomment %}
  window.marketAvailability = {{ product.metafields.custom.market_availability.value | json }};

  {% comment %}
    Warehouse-based availability. "Warehouse" metaobject entries (picked in
    Theme settings > Warehouse Availability) map a Shopify location to the
    storefront domains it serves: location (exact Shopify location name),
    domains (list of subdomain codes, "main" = bare domain), is_default
    (serves any domain not listed elsewhere). The custom.oos_warehouses
    metafield on the product and/or variant lists the location names
    currently out of stock (maintained by Shopify Flow). When either
    metafield is set it takes priority over the legacy market_availability
    JSON; when neither is set the legacy logic below still applies.
  {% endcomment %}
  window.warehouseByDomain = {
    {%- for wh in settings.warehouses -%}
      {%- assign wh_location = wh.location.value | strip | downcase -%}
      {%- if wh_location != blank and wh.domains.value -%}
        {%- for d in wh.domains.value %}
    {{ d | strip | downcase | json }}: {{ wh_location | json }},
        {%- endfor -%}
      {%- endif -%}
    {%- endfor %}
  };

  {%- assign default_warehouse = '' -%}
  {%- for wh in settings.warehouses -%}
    {%- if wh.is_default.value and default_warehouse == '' -%}
      {%- assign default_warehouse = wh.location.value | strip | downcase -%}
    {%- endif -%}
  {%- endfor %}
  window.defaultWarehouse = {{ default_warehouse | json }} || null;

  window.currentWarehouse = (function() {
    const parts = window.location.host.toLowerCase().replace(/^www\./, '').split('.');
    const code = parts.length === 2 ? 'main' : parts[0];
    return window.warehouseByDomain[code] || window.defaultWarehouse;
  })();

  {% comment %}
    custom.oos_warehouses is rewritten by Shopify Flow from live inventory;
    custom.oos_warehouses_manual is human-edited and never touched by Flow
    (use it to stop sales while stock exists). Both exist on product and
    variant and all set lists are merged. The manual list also accepts the
    special value "all" to stop sales on every domain.
  {% endcomment %}
  window.productOOSWarehouses = {{ product.metafields.custom.oos_warehouses.value | json }};
  window.productOOSManual = {{ product.metafields.custom.oos_warehouses_manual.value | json }};
  window.variantOOSWarehouses = {
    {% for variant in product.variants %}
      {{ variant.id }}: {{ variant.metafields.custom.oos_warehouses.value | json }}{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };
  window.variantOOSManual = {
    {% for variant in product.variants %}
      {{ variant.id }}: {{ variant.metafields.custom.oos_warehouses_manual.value | json }}{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  // Returns true/false when the warehouse metafields decide availability,
  // or null when they can't (no warehouse mapping configured, or no
  // metafield set) so the caller falls back to legacy logic.
  window.warehouseAvailability = function(variantId) {
    const norm = function(list) {
      return Array.isArray(list)
        ? list.map(function(w) { return String(w).toLowerCase().trim(); })
        : null;
    };

    const autoProduct = norm(window.productOOSWarehouses);
    const autoVariant = norm(window.variantOOSWarehouses[variantId]);
    const manualProduct = norm(window.productOOSManual);
    const manualVariant = norm(window.variantOOSManual[variantId]);

    const manual = (manualProduct || []).concat(manualVariant || []);
    if (manual.includes('all')) return false;

    if (!window.currentWarehouse) return null;
    if (autoProduct === null && autoVariant === null && manualProduct === null && manualVariant === null) return null;

    const oos = (autoProduct || []).concat(autoVariant || []).concat(manual);
    return !oos.includes(window.currentWarehouse);
  };

const waitlistBtn = document.querySelector('.custom-join-waitlist-btns');
const buyBtn = document.querySelector('.ctm-buy-btn');
const paymentBtn = document.querySelector('.custom-payment-btn');
const atcBtn = document.querySelector('.product-form__submit'); 
const deliveryDateInputForm = document.getElementById("delivery-date-input-final"); 
const deliveryDateInputUI = document.getElementById("delivery-date-input-custom");
const deliveryDateButtons = document.querySelectorAll(".delivery-date-button-custom");

const deliveryDateWrapper = document.querySelector('.delivery-date-wrapper-custom');
const requiredMessageClass = 'delivery-date-required-message'; 
const deliveryDateLabel = deliveryDateWrapper ? deliveryDateWrapper.querySelector('.delivery-date-label-custom') : null;
const requiredDeliveryDateMessage = {{ 'delivery.required_message' | t | json }};

function addRequiredMessage() {
  if (!deliveryDateWrapper) return;
  let messageSpan = deliveryDateWrapper.querySelector(`.${requiredMessageClass}`);
  
  if (!messageSpan) {
    messageSpan = document.createElement('span');
    messageSpan.className = requiredMessageClass;
    messageSpan.textContent = requiredDeliveryDateMessage;
    messageSpan.style.color = "red"; 
    messageSpan.style.display = "block";
    
    // Insert after the label if it exists, otherwise prepend
    if (deliveryDateLabel) {
      deliveryDateLabel.after(messageSpan);
    } else {
      deliveryDateWrapper.prepend(messageSpan); 
    }
  }
}

function removeRequiredMessage() {
  if (!deliveryDateWrapper) return;
  const messageSpan = deliveryDateWrapper.querySelector(`.${requiredMessageClass}`);
  if (messageSpan) {
    messageSpan.remove();
  }
}

function setSelectedDate(button, value) {
  deliveryDateButtons.forEach(b => b.classList.remove("active-custom"));
  if (button) {
    button.classList.add("active-custom");
  }

  if (deliveryDateInputUI) deliveryDateInputUI.value = value;    
  if (deliveryDateInputForm) deliveryDateInputForm.value = value;  
  
  updateButtonVisibilityAndState();
}

function updateButtonVisibilityAndState() {
  const url = new URL(window.location.href);
  let selectedVariant = url.searchParams.get("variant") || {{ product.selected_or_first_available_variant.id }};
  // The ?variant= parameter can carry an id from a different product (old
  // links, cross-domain language links). Shopify itself ignores foreign ids,
  // so judge availability by this product's variant instead.
  if (!(selectedVariant in window.variantOOSWarehouses)) {
    selectedVariant = {{ product.selected_or_first_available_variant.id }};
  }
  const metaList = window.marketAvailability || [];
  const currentDomain = window.location.host.toLowerCase();
  

  console.log(selectedVariant, "selectedVariant")


  let isAvailable = false;

  // 1. Check availability: warehouse metafields first, legacy market JSON otherwise
  if (selectedVariant) {
    const warehouseDecision = window.warehouseAvailability(selectedVariant);

    if (warehouseDecision !== null) {
      isAvailable = warehouseDecision;
    } else {
      const matchedVariant = metaList.find(m => {
        const sameVariant = String(m.variant_id) === String(selectedVariant);
        let metaDomain = m.domain ? m.domain.toLowerCase() : "";

        if (m.market && m.market.toLowerCase() === "gb") {
          metaDomain = "stendigcalendars.com";
        }

        const sameDomain = metaDomain === currentDomain;
        return sameVariant && sameDomain;
      });

      if (matchedVariant) {
        isAvailable = matchedVariant.qty > 0;
      }
    }
  }
  
  // 2. Check for Delivery Date Selection (FIXED: Check the value of the input, not the attribute)
  const isDateSelected = deliveryDateInputForm && deliveryDateInputForm.value;

  console.log("Is Available:", isAvailable, "Is Date Selected:", isDateSelected);
  console.log("Is Available:", isAvailable, "Is Date Selected:", isDateSelected);

  // --- Update Visibility Based on Availability ---
  if (isAvailable) {
    // Show Buy buttons, Hide Waitlist
    if (waitlistBtn) waitlistBtn.style.display = 'none';
    if (buyBtn) buyBtn.style.display = 'block';
    if (paymentBtn) paymentBtn.style.display = 'block';
    if (atcBtn) atcBtn.style.display = 'block';

    // --- Manage Required Message Display & Disabled State ---
    if (!isDateSelected) {
      addRequiredMessage(); 
      // Disable buttons if available but no date is selected
      if (atcBtn) atcBtn.disabled = true;
      if (buyBtn) buyBtn.disabled = true;
      if (paymentBtn) paymentBtn.disabled = true;
    } else {
      removeRequiredMessage(); 
      // Enable buttons if available AND a date is selected
      if (atcBtn) atcBtn.disabled = false;
      if (buyBtn) buyBtn.disabled = false; 
      if (paymentBtn) paymentBtn.disabled = false;
    }
    
  } else {
    // Hide Buy buttons, Show Waitlist
    if (waitlistBtn) waitlistBtn.style.display = 'flex';
    if (buyBtn) buyBtn.style.display = 'none';
    if (paymentBtn) paymentBtn.style.display = 'none';
    if (atcBtn) atcBtn.style.display = 'none';
    
    // Always ensure buttons are disabled if out of stock
    if (atcBtn) atcBtn.disabled = true;
    if (buyBtn) buyBtn.disabled = true;
    if (paymentBtn) paymentBtn.disabled = true;
    removeRequiredMessage(); // No need for date selection message if out of stock
  }
}

// --- Event Listeners for Variant Change (Triggers Availability Check) ---
const variantRadios = document.querySelectorAll('variant-radios input');
variantRadios.forEach(v => {
  v.addEventListener('change', () => {
    // Timeout to allow the URL param to update after variant change
    setTimeout(updateButtonVisibilityAndState, 200); 
  });
});

// --- Event Listeners for Delivery Date Selection (Triggers Date Check) ---
if (deliveryDateButtons.length) {
  deliveryDateButtons.forEach(btn => {
    btn.addEventListener("click", function () {
      const value = this.dataset.date;
      setSelectedDate(this, value);
    });
            });
          }

// --- Initial Load and ASAP Default Selection ---
document.addEventListener('DOMContentLoaded', () => {
  // Find the ASAP button
  const asapButton = Array.from(deliveryDateButtons).find(btn => btn.dataset.isAsap === 'true');
  
  if (asapButton) {
    // Select ASAP button by default
    setSelectedDate(asapButton, asapButton.dataset.date);
  }

  // Run the main check after a short delay
  setTimeout(updateButtonVisibilityAndState, 150); 
});

</script>


<script
  type="text/javascript"
>
  document.addEventListener('DOMContentLoaded', function() {
    // Auto-select first available variant for each option - works for all languages including Taiwanese
    function autoSelectFirstAvailable() {
      // Get all product form inputs (all variant option fieldsets)
      const productFormInputs = document.querySelectorAll('.product-form__input');

      // Loop through each option fieldset and auto-select first available (non-disabled) option
      productFormInputs.forEach(function(fieldset) {
        const inputs = fieldset.querySelectorAll('input[type="radio"]:not([disabled])');
        if (inputs.length > 0) {
          // Check if any input is already checked in this fieldset
          const hasChecked = fieldset.querySelector('input[type="radio"]:checked');

          // If no input is checked, select the first available (non-disabled) one
          if (!hasChecked) {
            // Use setTimeout to ensure Shopify's variant selectors have initialized
            setTimeout(function() {
              if (!fieldset.querySelector('input[type="radio"]:checked')) {
                inputs[0].click();
              }
            }, 50);
          }
        }
      });
    }

    // Run immediately on DOMContentLoaded
    autoSelectFirstAvailable();

    // Also run after delays to catch any Shopify async updates (for Taiwanese and other markets)
    setTimeout(autoSelectFirstAvailable, 100);
    setTimeout(autoSelectFirstAvailable, 300);
  });
</script>

