<style>
  .delivery-date-options-custom {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 6px;
  }

  .delivery-date-label-custom {
    font-size: 13px;
    margin-bottom: 6px;
    display: block;
  }

  .delivery-date-button-custom {
    padding: 1rem 2rem;
    border: 1px solid #d3d3d3;
    border-radius: 25px;
    background: #fff;
    font-size: 1.4rem;
    cursor: pointer;
    transition: 0.12s ease;
  }

  .delivery-date-button-custom:hover {
    border-color: #000;
  }

  .delivery-date-button-custom.active-custom {
    background: #000;
    color: #fff;
    border-color: #000;
  }

  .delivery-date-wrapper-custom {
    margin-top: 12px;
  }
</style>

{% assign current_domain = request.host | downcase | remove: 'www.' %}

{% comment %}
  Rules can target a full hostname (e.g. "de.stendigcalendars.com") or just the
  subdomain code (e.g. "de"). Use "main" for the bare domain (stendigcalendars.com).
{% endcomment %}
{% assign host_parts = current_domain | split: '.' %}
{% if host_parts.size == 2 %}
  {% assign current_subdomain = 'main' %}
{% else %}
  {% assign current_subdomain = host_parts | first %}
{% endif %}

{% comment %}
  Per-product exclusions (custom.delivery_domain_rule metafield):
  entries of { domain, exclude_date } hide the named dates on that domain
  for this product only. Applies to both data sources below.
{% endcomment %}
{% assign rule_list = product.metafields.custom.delivery_domain_rule.value %}
{% assign excluded_raw = '' %}

{% if rule_list %}
  {% for entry in rule_list %}
    {% assign entry_domain = entry.domain | downcase | remove: 'www.' | strip %}

    {% if entry_domain == current_domain or entry_domain == current_subdomain %}
      {% assign exclude_string = entry.exclude_date | strip %}

      {% if exclude_string != '' %}
        {% assign exclude_array = exclude_string | split: ',' %}
        {% for ex in exclude_array %}
          {% assign ex_clean = ex | strip %}
          {% assign excluded_raw = excluded_raw | append: ex_clean | append: '||' %}
        {% endfor %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign excluded = excluded_raw | split: '||' | uniq %}

{% assign final_list = '' %}
{% assign label_list = '' %}

{% if settings.delivery_date_entries.count > 0 %}
  {% comment %}
    Primary source: "Delivery date option" metaobjects picked in theme settings.
    Field keys:
      date    - real date field (picker); auto-hides once the date has passed
      special - non-date options: "ASAP" or "By Xmas" (used when date is empty)
      label   - optional display override, translatable via T Lab
      hide_on - list of subdomain codes / hostnames, "main" = bare domain
      expires - optional date; entry hidden after this day (mainly for specials)
    The value stored on the order (data-date) is always English: "10 Dec",
    "ASAP" or "By Xmas". The displayed label is localized via the theme
    locale keys delivery.date_label / delivery.months.* / delivery.date_options.*.
  {% endcomment %}
  {% assign month_keys = 'jan,feb,mar,apr,may,jun,jul,aug,sep,oct,nov,dec' | split: ',' %}
  {% assign months_en = 'Jan,Feb,Mar,Apr,May,Jun,Jul,Aug,Sep,Oct,Nov,Dec' | split: ',' %}
  {% assign today_num = 'now' | date: '%Y%m%d' | plus: 0 %}
  {% assign today_mmdd = 'now' | date: '%m%d' | plus: 0 %}

  {% for entry in settings.delivery_date_entries %}
    {% assign special = entry.special.value | strip %}
    {% assign date_string = '' %}
    {% assign generated_label = '' %}

    {% if special != blank %}
      {% assign date_string = special %}
      {% assign special_down = special | downcase %}
      {% if special_down == 'asap' %}
        {% assign generated_label = 'delivery.date_options.asap' | t %}
      {% elsif special_down == 'by xmas' or special_down == 'by christmas' %}
        {% if today_mmdd > 1225 %}{% continue %}{% endif %}
        {% assign generated_label = 'delivery.date_options.by_xmas' | t %}
      {% else %}
        {% assign generated_label = special %}
      {% endif %}
    {% elsif entry.date.value %}
      {% assign date_num = entry.date.value | date: '%Y%m%d' | plus: 0 %}
      {% if today_num > date_num %}{% continue %}{% endif %}

      {% assign day_num = entry.date.value | date: '%d' | plus: 0 %}
      {% assign month_index = entry.date.value | date: '%m' | plus: 0 | minus: 1 %}
      {% assign date_string = day_num | append: ' ' | append: months_en[month_index] %}

      {% assign month_key = 'delivery.months.' | append: month_keys[month_index] %}
      {% assign month_translated = month_key | t %}
      {% assign generated_label = 'delivery.date_label' | t: day: day_num, month: month_translated %}
    {% else %}
      {% continue %}
    {% endif %}

    {% if excluded contains date_string %}{% continue %}{% endif %}

    {% assign hidden_here = false %}
    {% if entry.hide_on.value %}
      {% for h in entry.hide_on.value %}
        {% assign h_clean = h | downcase | remove: 'www.' | strip %}
        {% if h_clean == current_domain or h_clean == current_subdomain %}
          {% assign hidden_here = true %}
        {% endif %}
      {% endfor %}
    {% endif %}
    {% if hidden_here %}{% continue %}{% endif %}

    {% if entry.expires.value %}
      {% assign expires_num = entry.expires.value | date: '%Y%m%d' | plus: 0 %}
      {% if today_num > expires_num %}{% continue %}{% endif %}
    {% endif %}

    {% assign custom_label = entry.label.value | default: '' | strip %}
    {% if custom_label != blank %}
      {% assign generated_label = custom_label %}
    {% endif %}

    {% assign final_list = final_list | append: date_string | append: '||' %}
    {% assign label_list = label_list | append: generated_label | append: '||' %}
  {% endfor %}
{% else %}
  {% comment %} Legacy fallback: comma-separated list from theme settings. {% endcomment %}
  {% assign cleaned_text = settings.delivery_dates | strip_html | strip %}
  {% assign global_dates = cleaned_text | split: ',' %}

  {% for d in global_dates %}
    {% assign dd = d | strip %}
    {% if dd != '' %}
      {% unless excluded contains dd %}
        {% assign final_list = final_list | append: dd | append: '||' %}
      {% endunless %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign final_dates = final_list | split: '||' %}
{% assign final_labels = label_list | split: '||' %}

<div class="delivery-date-wrapper-custom">
  <label class="delivery-date-label-custom">{{ 'delivery.choose_date' | t }}</label>

  <div class="delivery-date-options-custom">
    {% for d in final_dates %}
      {% if d != '' %}
        {% assign raw_date = d | strip %}
        {% assign normalized_date = raw_date | downcase %}
        {% assign button_label = raw_date %}
        {% assign is_asap = false %}
        {% assign custom_label = final_labels[forloop.index0] %}

        {% if normalized_date == 'asap' %}
          {% assign is_asap = true %}
        {% endif %}

        {% if custom_label != blank %}
          {% assign button_label = custom_label %}
        {% elsif normalized_date == 'asap' %}
          {% assign button_label = 'delivery.date_options.asap' | t %}
        {% elsif normalized_date == 'by xmas' or normalized_date == 'by christmas' %}
          {% assign button_label = 'delivery.date_options.by_xmas' | t %}
        {% else %}
          {% assign date_parts = raw_date | split: ' ' %}
          {% if date_parts.size == 2 %}
            {% assign day_part = date_parts[0] | remove: ',' %}
            {% assign month_part = date_parts[1] | remove: ',' | downcase %}
            {% assign month_translation = '' %}

            {% case month_part %}
              {% when 'jan' %}
                {% assign month_translation = 'delivery.months.jan' | t %}
              {% when 'january' %}
                {% assign month_translation = 'delivery.months.jan' | t %}
              {% when 'feb' %}
                {% assign month_translation = 'delivery.months.feb' | t %}
              {% when 'february' %}
                {% assign month_translation = 'delivery.months.feb' | t %}
              {% when 'mar' %}
                {% assign month_translation = 'delivery.months.mar' | t %}
              {% when 'march' %}
                {% assign month_translation = 'delivery.months.mar' | t %}
              {% when 'apr' %}
                {% assign month_translation = 'delivery.months.apr' | t %}
              {% when 'april' %}
                {% assign month_translation = 'delivery.months.apr' | t %}
              {% when 'may' %}
                {% assign month_translation = 'delivery.months.may' | t %}
              {% when 'jun' %}
                {% assign month_translation = 'delivery.months.jun' | t %}
              {% when 'june' %}
                {% assign month_translation = 'delivery.months.jun' | t %}
              {% when 'jul' %}
                {% assign month_translation = 'delivery.months.jul' | t %}
              {% when 'july' %}
                {% assign month_translation = 'delivery.months.jul' | t %}
              {% when 'aug' %}
                {% assign month_translation = 'delivery.months.aug' | t %}
              {% when 'august' %}
                {% assign month_translation = 'delivery.months.aug' | t %}
              {% when 'Sep' %}
                {% assign month_translation = 'delivery.months.sep' | t %}
              {% when 'sept' %}
                {% assign month_translation = 'delivery.months.sep' | t %}
              {% when 'september' %}
                {% assign month_translation = 'delivery.months.sep' | t %}
              {% when 'oct' %}
                {% assign month_translation = 'delivery.months.oct' | t %}
              {% when 'october' %}
                {% assign month_translation = 'delivery.months.oct' | t %}
              {% when 'nov' %}
                {% assign month_translation = 'delivery.months.nov' | t %}
              {% when 'november' %}
                {% assign month_translation = 'delivery.months.nov' | t %}
              {% when 'dec' %}
                {% assign month_translation = 'delivery.months.dec' | t %}
              {% when 'december' %}
                {% assign month_translation = 'delivery.months.dec' | t %}
            {% endcase %}

            {% if month_translation != '' %}
              {% assign button_label = day_part | append: ' ' | append: month_translation %}
            {% endif %}
          {% endif %}
        {% endif %}

        <button
          type="button"
          class="delivery-date-button-custom"
          data-date="{{ raw_date }}"
          {% if is_asap %}
            data-is-asap="true"
          {% endif %}
        >
          {{ button_label }}
        </button>
      {% endif %}
    {% endfor %}
  </div>

  <input
    type="hidden"
    name="properties[Delivery Date]"
    id="delivery-date-input-custom"
    required
  >
</div>
